{
  "name": "quizz",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "//": "NB: ne pas nommer un script `setup` — c'est une commande interne de pnpm.",
    "bootstrap": "pnpm shared:build",
    "shared:build": "pnpm --filter @quizz/shared build",
    "shared:watch": "pnpm --filter @quizz/shared dev",
    "dev:mobile": "pnpm --filter @quizz/mobile start",
    "dev:display": "pnpm --filter @quizz/display dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "//sb": "CLI Supabase via npx : l'installation globale n'est pas supportee, et l'install locale echoue en EPERM sous Windows (antivirus).",
    "sb": "npx --yes supabase@latest",
    "sb:link": "npx --yes supabase@latest link",
    "sb:deploy": "npx --yes supabase@latest functions deploy",
    "sb:logs": "npx --yes supabase@latest functions logs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver",
      "esbuild"
    ]
  }
}
