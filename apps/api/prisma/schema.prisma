// Prisma schema — PostgreSQL hébergé sur Supabase.
// Les questions du quiz restent en JSON statique (pas en base) ;
// seule la donnée de jeu (sessions, tentatives, résultats) est persistée.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connexion applicative : passe par le pooler (PgBouncer, port 6543).
  url       = env("DATABASE_URL")
  // Les migrations exigent une connexion directe (port 5432) : PgBouncer ne
  // supporte pas les instructions DDL en mode transaction.
  directUrl = env("DIRECT_URL")
}

enum Category {
  kpop
  anime
}

/// Une partie jouée par un participant, rattachée à son ticket physique.
model Session {
  id         String   @id @default(cuid())
  /// Numéro du ticket physique (4 chiffres) remis par l'organisation.
  ticket     String
  /// Pseudonyme facultatif : le ticket seul suffit à identifier le joueur.
  playerName String?
  category   Category
  createdAt  DateTime @default(now())

  attempts Attempt[]
  result   Result?

  /// Un ticket ne joue qu'une fois : le choix de catégorie est définitif.
  @@unique([ticket])
  @@index([category])
}

/// Une réponse d'un joueur à une question. `questionId` référence
/// une question du JSON statique, pas une table.
model Attempt {
  id          String   @id @default(cuid())
  sessionId   String
  questionId  String
  chosenIndex Int? // null = temps écoulé
  isCorrect   Boolean  @default(false)
  answerMs    Int
  createdAt   DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  /// Une seule réponse par question et par session : empêche de rejouer
  /// une question déjà répondue pour accumuler des points.
  @@unique([sessionId, questionId])
  @@index([sessionId])
}

/// Résultat final d'une session. Sert au classement général (toutes
/// catégories confondues, conformément à la maquette).
model Result {
  id           String   @id @default(cuid())
  sessionId    String   @unique
  ticket       String
  playerName   String?
  category     Category
  /// Nombre de bonnes réponses, affiché sous la forme `score`/20.
  score        Int      @default(0)
  totalMs      Int      @default(0)
  qualified    Boolean  @default(false)
  createdAt    DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([score, totalMs])
}

/// Images du 2e tour : silhouette affichée d'abord, puis photo révélée.
model Round2Image {
  id            String   @id @default(cuid())
  /// Ordre d'affichage dans le diaporama (1..N).
  position      Int      @unique
  category      Category
  /// Silhouette (PNG noir sur fond uni) montrée en premier.
  silhouetteUrl String
  /// Photo réelle, révélée à la demande de l'animateur.
  photoUrl      String
  /// Réponse attendue (nom de l'idole ou du personnage).
  answer        String
  createdAt     DateTime @default(now())
}
