# MySQL/MariaDB via XAMPP ou WAMP (défaut : user root, mot de passe vide, port 3306).
# Crée la base "quizz" (phpMyAdmin ou `CREATE DATABASE quizz;`) puis lance :
#   pnpm --filter @quizz/api prisma:migrate
DATABASE_URL="mysql://root:@localhost:3306/quizz"

# Port de l'API NestJS (3000 = écran display, 3001 souvent pris → 3333)
PORT=3333
